# vim:ft=plumed
# Generic US-REMD template: umbrella sampling windows run as MPI replicas with exchange
# A single plumed.dat is shared by all replicas via -plumed flag.
# GROMACS assigns each MPI rank its own AT= value from the @replicas: list.
# Output: GROMACS appends the replica index to the FILE name
#         (colvar_multi.0.dat, colvar_multi.1.dat, ...)
#
# Run command:
#   mpiexec -np N_REPLICAS gmx_mpi mdrun \
#       -multidir rep_0 rep_1 ... rep_{N-1} \
#       -plumed ../plumed_us_remd.dat \
#       -nsteps NSTEPS [-replex 200]
#
# Replace CAPS placeholders:
#   CV1_DEFINITION       — reaction coordinate (TORSION, DISTANCE, RMSD, CUSTOM, ...)
#   SECONDARY_CV         — optional monitor-only CV (remove if not needed)
#   REFERENCE_PDB        — for MOLINFO; path is relative to each replica directory
#   KAPPA_VALUE          — spring constant (kJ/mol/unit²)
#   AT_VALUE_i           — window center for replica i
#                          Generate: np.linspace(MIN, MAX, N, endpoint=False_for_periodic)

MOLINFO STRUCTURE=../REFERENCE_PDB  # path relative to replica directory; remove if unused

cv1: CV1_DEFINITION
secondary: SECONDARY_CV_DEFINITION  # optional; remove if not needed

bb: RESTRAINT ARG=cv1 KAPPA=KAPPA_VALUE \
    AT=@replicas:AT_VALUE_0,AT_VALUE_1,AT_VALUE_2,...

PRINT ARG=cv1,secondary,bb.bias FILE=../colvar_multi.dat STRIDE=100
