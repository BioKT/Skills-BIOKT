# Source:  PLUMED Masterclass 21.3 — Umbrella Sampling
# Author:  Giovanni Bussi (2021)
#          https://github.com/plumed/masterclass-21-3
# Copied from the masterclass solution files for reference. Adapt CV definitions for your system.
# vim:ft=plumed
MOLINFO STRUCTURE=../data/reference.pdb
phi: TORSION ATOMS=@phi-2 
psi: TORSION ATOMS=@psi-2 
bb: RESTRAINT ARG=phi KAPPA=200.0 AT=0
PRINT ARG=phi,psi,bb.bias FILE=colvar_0.dat STRIDE=100
# make sure that each simulation writes on a different file
# e.g. colvar_multi_0.dat, colvar_multi_1.dat, ...
